{
  "name": "claude-code-ai-observability",
  "version": "0.1.5",
  "description": "Comprehensive AI Agent Observability plugin for Claude Code — realtime Sentry traces with per-turn tokens, cost, subagent and error instrumentation, and rich auto-tagging (session / git / host).",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "smoke": "bash scripts/smoke-test.sh",
    "ci": "tsc --noEmit && vitest run && bash scripts/smoke-test.sh",
    "postinstall": "cd scripts && npm install"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "sentry",
    "observability",
    "ai-monitoring",
    "opentelemetry",
    "ai-agents"
  ],
  "author": "Joshkop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Joshkop/claude-code-ai-observability"
  },
  "dependencies": {
    "@sentry/node": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.0"
  }
}
